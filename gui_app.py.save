import customtkinter as ctk
import sys
import threading
# Naye professional modules ko import kar rahe hain
from modules.waf_detector import detect_waf
from modules.subdomain_scanner import find_subdomains
from modules.vulnerability_scanner import scan_vulnerabilities

# GUI setup aur Terminal redirection logic
class TerminalRedirector:
    def __init__(self, text_widget):
        self.text_widget = text_widget
    def write(self, string):
        self.text_widget.insert("end", string)
        self.text_widget.see("end")
        self.text_widget.update_idletasks()
    def flush(self):
  
# --- MAIN LOGIC FUNCTION ---
def start_recon(target):
    if not target or target == "https://":
        print("[!] Error: Please enter a valid target URL/Domain.")
        return

    print(f"\n{'='*60}")
    print(f"[*] INITIALIZING PRO-RECON ON: {target}")
    print(f"{'='*60}\n")

    # Domain nikalne ki logic (e.g., google.com)
    domain_only = target.replace("https://", "").replace("http://", "").split("/")[0]

    try:
        # --- STAGE 1: WAF DETECTION ---
        print("[*] Stage 1: Identifying Firewall (WAF)...")
        waf_info = detect_waf(target)
        print(f"{waf_info}")

        # --- STAGE 2: SUBDOMAIN ENUMERATION ---
        print("\n[*] Stage 2: Enumerating Subdomains (Passive Scan)...")
        sub_info = find_subdomains(domain_only)
        print(f"{sub_info}")

        # --- STAGE 3: VULNERABILITY SCANNING ---
        print("\n[*] Stage 3: Scanning for Sensitive File Exposure...")
        vuln_info = scan_vulnerabilities(target)
        print(f"{vuln_info}")

    except Exception as e:
        print(f"[!] Critical Error during scan: {str(e)}")

    print(f"\n{'-'*60}")
    print("[+] Professional Reconnaissance Phase Complete.")
    print(f"{'-'*60}\n")

# --- GUI CLASS ---
class ReconLitePro(ctk.CTk):
    def __init__(self):
        super().__init__()

        self.title("ReconLite Pro v2.0 | Advanced Security Suite")
        self.geometry("1000x700")
        ctk.set_appearance_mode("dark")

        # UI Layout
        self.label = ctk.CTkLabel(self, text="Professional Reconnaissance Tool", font=("Terminal", 24, "bold"))
        self.label.pack(pady=20)

        self.url_entry = ctk.CTkEntry(self, placeholder_text="Enter Target (e.g., https://example.com)", width=500)
        self.url_entry.pack(pady=10)
        self.url_entry.insert(0, "https://")

        self.scan_btn = ctk.CTkButton(self, text="START PRO SCAN", command=self.run_thread, fg_color="green", hover_color="darkgreen")
        self.scan_btn.pack(pady=20)

        # Output Terminal Area
        self.result_area = ctk.CTkTextbox(self, width=900, height=400, font=("Consolas", 14), text_color="#00FF00", fg_color="#1a1a1a")
        self.result_area.pack(pady=10, padx=20)

        # Redirecting Print to GUI
        sys.stdout = TerminalRedirector(self.result_area)

    def run_thread(self):
        # Multithreading taakay scan ke doran GUI hang na ho
        target = self.url_entry.get()
        t = threading.Thread(target=start_recon, args=(target,))
        t.start()

if __name__ == "__main__":
    app = ReconLitePro()
    app.mainloop()
